# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/trekmarket

# Replit OIDC client ID (your Repl's ID)
REPL_ID=your-repl-id-here

# OIDC issuer URL (defaults to https://replit.com/oidc if not set)
ISSUER_URL=https://replit.com/oidc

# Port the API server listens on
PORT=8080

# Base path prefix for the API (e.g. / or /api)
BASE_PATH=/

# REQUIRED: Comma-separated list of allowed CORS origins.
# Must exactly match the origin(s) your frontend is served from.
# Example: https://myapp.replit.app
# Example (multiple): https://myapp.replit.app,https://staging.myapp.com
ALLOWED_ORIGIN=https://your-frontend-origin.example.com

# SendGrid (or compatible) API key for transactional email
SENDGRID_API_KEY=your-sendgrid-api-key-here

# OpenWeatherMap API key for real-time weather on trek pages
# Get one free at https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweathermap-api-key-here

# Payment gateways for permit purchasing
# Khalti (Nepal domestic) — https://docs.khalti.com/
KHALTI_SECRET_KEY=your-khalti-secret-key-here

# eSewa (Nepal domestic) — https://developer.esewa.com.np/
ESEWA_MERCHANT_CODE=your-esewa-merchant-code-here
ESEWA_SECRET_KEY=your-esewa-secret-key-here

# Stripe (International card payments) — https://stripe.com/docs
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here

# Platform commission percentage deducted from each booking (default: 5)
PLATFORM_COMMISSION_PERCENT=5

# Twilio (SMS for SOS alerts) — https://www.twilio.com/docs
# If not configured, SMS will be skipped but emails and in-app alerts still work.
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE_NUMBER=+1234567890
